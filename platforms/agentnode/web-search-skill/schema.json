{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Web Search Skill API Schema",
  "description": "JSON Schema for the Web Search Skill API endpoints and data structures",
  "definitions": {
    "SearchOptions": {
      "type": "object",
      "properties": {
        "num_results": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10,
          "description": "Number of results to return"
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000,
          "default": 0,
          "description": "Offset for pagination"
        },
        "language": {
          "type": "string",
          "default": "en",
          "description": "ISO 639-1 language code for results"
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 country code for location-aware results"
        },
        "safe_search": {
          "type": "string",
          "enum": ["off", "moderate", "strict"],
          "default": "moderate"
        },
        "date_range": {
          "type": "object",
          "properties": {
            "start": {"type": "string", "format": "date"},
            "end": {"type": "string", "format": "date"}
          }
        },
        "freshness": {
          "type": "string",
          "enum": ["day", "week", "month", "year"],
          "description": "Filter by content freshness"
        },
        "search_type": {
          "type": "string",
          "enum": ["web", "news", "images", "videos", "scholarly"],
          "default": "web"
        },
        "site_filter": {
          "type": "string",
          "description": "Restrict search to specific site (e.g., 'wikipedia.org')"
        },
        "exclude_sites": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Sites to exclude from results"
        }
      }
    },
    "SearchResult": {
      "type": "object",
      "properties": {
        "position": {
          "type": "integer",
          "description": "Position in result list"
        },
        "title": {
          "type": "string",
          "description": "Page title"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Result URL"
        },
        "display_url": {
          "type": "string",
          "description": "Display-formatted URL"
        },
        "snippet": {
          "type": "string",
          "description": "Text snippet from the page"
        },
        "published_date": {
          "type": "string",
          "format": "date-time",
          "description": "Publication date if available"
        },
        "source": {
          "type": "string",
          "description": "Source domain"
        },
        "language": {
          "type": "string",
          "description": "Detected language"
        },
        "result_type": {
          "type": "string",
          "enum": ["web_page", "news", "image", "video", "pdf", "scholarly"],
          "description": "Type of search result"
        },
        "thumbnail": {
          "type": "string",
          "format": "uri",
          "description": "Thumbnail URL if available"
        },
        "metadata": {
          "type": "object",
          "description": "Additional result metadata"
        }
      }
    },
    "SearchResponse": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Original search query"
        },
        "original_query": {
          "type": "string",
          "description": "Query before any modifications"
        },
        "results": {
          "type": "array",
          "items": {"$ref": "#/definitions/SearchResult"}
        },
        "total_results": {
          "type": "integer",
          "description": "Estimated total results available"
        },
        "search_time_ms": {
          "type": "integer",
          "description": "Time taken to perform search"
        },
        "search_type": {
          "type": "string"
        },
        "page_info": {
          "type": "object",
          "properties": {
            "current_page": {"type": "integer"},
            "results_per_page": {"type": "integer"},
            "has_next_page": {"type": "boolean"}
          }
        },
        "related_searches": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Related search suggestions"
        }
      }
    },
    "BatchSearchRequest": {
      "type": "object",
      "properties": {
        "queries": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1,
          "maxItems": 25
        },
        "options": {"$ref": "#/definitions/SearchOptions"}
      },
      "required": ["queries"]
    },
    "SuggestRequest": {
      "type": "object",
      "properties": {
        "partial_query": {
          "type": "string",
          "description": "Partial query to get suggestions for"
        },
        "language": {
          "type": "string",
          "default": "en"
        },
        "max_suggestions": {
          "type": "integer",
          "default": 10
        }
      },
      "required": ["partial_query"]
    },
    "Error": {
      "type": "object",
      "properties": {
        "code": {"type": "string"},
        "message": {"type": "string"},
        "details": {"type": "object"}
      },
      "required": ["code", "message"]
    }
  },
  "SearchRequest": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500,
        "description": "Search query"
      },
      "options": {"$ref": "#/definitions/SearchOptions"}
    },
    "required": ["query"]
  }
}
