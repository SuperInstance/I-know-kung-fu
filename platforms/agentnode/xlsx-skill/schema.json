{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XLSX Skill API Schema",
  "description": "JSON Schema for the XLSX Skill API endpoints and data structures",
  "definitions": {
    "WorkbookOptions": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Workbook title"
        },
        "author": {
          "type": "string",
          "description": "Workbook author"
        },
        "subject": {
          "type": "string",
          "description": "Workbook subject"
        },
        "default_sheet_name": {
          "type": "string",
          "default": "Sheet1"
        }
      }
    },
    "CellReference": {
      "type": "string",
      "pattern": "^[A-Z]{1,3}[1-9][0-9]*$",
      "description": "Excel cell reference (e.g., A1, B15, AA100)"
    },
    "RangeReference": {
      "type": "string",
      "pattern": "^[A-Z]{1,3}[1-9][0-9]*:[A-Z]{1,3}[1-9][0-9]*$",
      "description": "Excel range reference (e.g., A1:B10)"
    },
    "CellStyle": {
      "type": "object",
      "properties": {
        "font": {
          "type": "object",
          "properties": {
            "name": {"type": "string", "default": "Calibri"},
            "size": {"type": "integer", "minimum": 8, "maximum": 72, "default": 11},
            "bold": {"type": "boolean", "default": false},
            "italic": {"type": "boolean", "default": false},
            "underline": {"type": "boolean", "default": false},
            "strikethrough": {"type": "boolean", "default": false},
            "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
          }
        },
        "fill": {
          "type": "object",
          "properties": {
            "type": {"type": "string", "enum": ["solid", "pattern", "gradient"]},
            "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
            "pattern_type": {"type": "string"}
          }
        },
        "border": {
          "type": "object",
          "properties": {
            "top": {"type": "object"},
            "bottom": {"type": "object"},
            "left": {"type": "object"},
            "right": {"type": "object"}
          }
        },
        "alignment": {
          "type": "object",
          "properties": {
            "horizontal": {"type": "string", "enum": ["left", "center", "right", "fill", "justify"]},
            "vertical": {"type": "string", "enum": ["top", "center", "bottom", "justify"]},
            "wrap_text": {"type": "boolean", "default": false},
            "text_rotation": {"type": "integer", "minimum": -90, "maximum": 90}
          }
        },
        "number_format": {
          "type": "string",
          "description": "Excel number format code"
        }
      }
    },
    "Cell": {
      "type": "object",
      "properties": {
        "reference": {"$ref": "#/definitions/CellReference"},
        "value": {
          "type": ["string", "number", "boolean", "null"],
          "description": "Cell value"
        },
        "formula": {
          "type": "string",
          "description": "Excel formula (without = prefix)"
        },
        "style": {"$ref": "#/definitions/CellStyle"},
        "data_type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "date", "datetime", "formula"],
          "description": "Explicit data type for the cell"
        },
        "comment": {
          "type": "object",
          "properties": {
            "text": {"type": "string"},
            "author": {"type": "string"}
          }
        },
        "hyperlink": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "Worksheet": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Worksheet name",
          "maxLength": 31
        },
        "data": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "any"}
          },
          "description": "2D array of cell values"
        },
        "cells": {
          "type": "array",
          "items": {"$ref": "#/definitions/Cell"},
          "description": "Individual cell definitions with styles"
        },
        "formulas": {
          "type": "object",
          "additionalProperties": {"type": "string"},
          "description": "Map of cell references to formulas"
        },
        "styles": {
          "type": "object",
          "description": "Style definitions"
        },
        "column_widths": {
          "type": "object",
          "additionalProperties": {"type": "number"},
          "description": "Column letter to width mapping"
        },
        "row_heights": {
          "type": "object",
          "additionalProperties": {"type": "number"},
          "description": "Row number to height mapping"
        },
        "hidden_rows": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "hidden_columns": {
          "type": "array",
          "items": {"type": "string"}
        },
        "frozen_panes": {
          "type": "object",
          "properties": {
            "rows": {"type": "integer"},
            "columns": {"type": "integer"}
          }
        },
        "protection": {
          "type": "object",
          "properties": {
            "protected": {"type": "boolean"},
            "password": {"type": "string"}
          }
        }
      }
    },
    "Chart": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["column", "bar", "line", "area", "pie", "doughnut", "scatter", "bubble", "combo"],
          "description": "Chart type"
        },
        "title": {"type": "string"},
        "data_range": {"$ref": "#/definitions/RangeReference"},
        "categories": {
          "type": "object",
          "properties": {
            "range": {"$ref": "#/definitions/RangeReference"},
            "title": {"type": "string"}
          }
        },
        "series": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "range": {"$ref": "#/definitions/RangeReference"},
              "chart_type": {"type": "string"},
              "axis": {"type": "string", "enum": ["primary", "secondary"]}
            }
          }
        },
        "axes": {
          "type": "object",
          "properties": {
            "x_axis": {
              "type": "object",
              "properties": {
                "title": {"type": "string"},
                "logarithmic": {"type": "boolean"}
              }
            },
            "y_axis": {
              "type": "object",
              "properties": {
                "title": {"type": "string"},
                "logarithmic": {"type": "boolean"},
                "min": {"type": "number"},
                "max": {"type": "number"}
              }
            }
          }
        },
        "legend": {
          "type": "object",
          "properties": {
            "show": {"type": "boolean", "default": true},
            "position": {"type": "string", "enum": ["bottom", "right", "top", "left"]}
          }
        },
        "position": {
          "type": "object",
          "properties": {
            "sheet": {"type": "string"},
            "anchor_cell": {"$ref": "#/definitions/CellReference"},
            "width": {"type": "number"},
            "height": {"type": "number"}
          }
        }
      },
      "required": ["type", "data_range"]
    },
    "PivotTable": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "source_range": {"$ref": "#/definitions/RangeReference"},
        "destination": {"$ref": "#/definitions/CellReference"},
        "rows": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Field names for row labels"
        },
        "columns": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Field names for column labels"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {"type": "string"},
              "function": {"type": "string", "enum": ["sum", "count", "average", "max", "min", "product", "stddev", "var"]},
              "name": {"type": "string"}
            }
          }
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {"type": "string"},
              "values": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      },
      "required": ["source_range", "rows", "values"]
    },
    "ConditionalFormat": {
      "type": "object",
      "properties": {
        "range": {"$ref": "#/definitions/RangeReference"},
        "type": {
          "type": "string",
          "enum": ["cell_value", "formula", "color_scale", "data_bar", "icon_set", "duplicate", "unique", "top10", "above_average"]
        },
        "criteria": {
          "type": "object",
          "properties": {
            "operator": {"type": "string"},
            "value": {"type": ["string", "number"]},
            "formula": {"type": "string"}
          }
        },
        "format": {"$ref": "#/definitions/CellStyle"},
        "color_scale": {
          "type": "object",
          "properties": {
            "min_color": {"type": "string"},
            "mid_color": {"type": "string"},
            "max_color": {"type": "string"}
          }
        },
        "data_bar": {
          "type": "object",
          "properties": {
            "color": {"type": "string"},
            "show_value": {"type": "boolean"}
          }
        }
      }
    },
    "NamedRange": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "reference": {"type": "string"},
        "scope": {"type": "string", "enum": ["workbook", "worksheet"]},
        "comment": {"type": "string"}
      },
      "required": ["name", "reference"]
    },
    "DataValidation": {
      "type": "object",
      "properties": {
        "range": {"$ref": "#/definitions/RangeReference"},
        "type": {
          "type": "string",
          "enum": ["list", "whole", "decimal", "date", "time", "text_length", "custom"]
        },
        "operator": {"type": "string"},
        "formula1": {"type": "string"},
        "formula2": {"type": "string"},
        "show_error": {"type": "boolean", "default": true},
        "error_title": {"type": "string"},
        "error_message": {"type": "string"},
        "show_input": {"type": "boolean", "default": true},
        "input_title": {"type": "string"},
        "input_message": {"type": "string"}
      }
    },
    "Error": {
      "type": "object",
      "properties": {
        "code": {"type": "string"},
        "message": {"type": "string"},
        "details": {"type": "object"}
      },
      "required": ["code", "message"]
    }
  },
  "CreateWorkbookRequest": {
    "type": "object",
    "properties": {
      "options": {"$ref": "#/definitions/WorkbookOptions"},
      "worksheets": {
        "type": "array",
        "items": {"$ref": "#/definitions/Worksheet"}
      },
      "named_ranges": {
        "type": "array",
        "items": {"$ref": "#/definitions/NamedRange"}
      },
      "charts": {
        "type": "array",
        "items": {"$ref": "#/definitions/Chart"}
      }
    }
  },
  "ReadCellsRequest": {
    "type": "object",
    "properties": {
      "document_id": {"type": "string"},
      "document_url": {"type": "string", "format": "uri"},
      "sheet_name": {"type": "string"},
      "range": {"$ref": "#/definitions/RangeReference"},
      "include_formulas": {"type": "boolean", "default": false},
      "include_styles": {"type": "boolean", "default": false},
      "include_comments": {"type": "boolean", "default": false}
    }
  },
  "WriteCellsRequest": {
    "type": "object",
    "properties": {
      "document_id": {"type": "string"},
      "sheet_name": {"type": "string"},
      "cells": {
        "type": "array",
        "items": {"$ref": "#/definitions/Cell"}
      },
      "data": {
        "type": "array",
        "items": {"type": "array"},
        "description": "2D array starting at A1"
      }
    }
  },
  "CalculateRequest": {
    "type": "object",
    "properties": {
      "document_id": {"type": "string"},
      "sheet_name": {"type": "string"},
      "range": {"$ref": "#/definitions/RangeReference"},
      "full_calculation": {"type": "boolean", "default": true}
    }
  }
}
