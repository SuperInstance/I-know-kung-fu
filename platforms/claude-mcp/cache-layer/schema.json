{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cache Layer MCP Server",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "const": "cache-layer" },
        "version": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "enum": ["get", "set", "delete", "invalidate_by_tag", "clear", "get_stats", "warm_cache", "configure_ttl"]
          }
        }
      }
    }
  }
}
