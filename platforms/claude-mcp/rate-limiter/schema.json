{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rate Limiter MCP Server",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "const": "rate-limiter" },
        "version": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "enum": ["check_rate_limit", "create_quota", "apply_quota", "get_usage", "reset_limit", "set_priority", "get_stats", "configure_backoff"]
          }
        }
      }
    }
  }
}
