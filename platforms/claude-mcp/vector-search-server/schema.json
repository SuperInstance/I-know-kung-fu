{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vector Search Server MCP",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "const": "vector-search-server" },
        "version": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "enum": ["create_index", "delete_index", "add_vectors", "search", "hybrid_search", "delete_vectors", "get_index_stats", "list_indices", "generate_embeddings", "batch_search"]
          }
        }
      }
    }
  }
}
