{
  "name": "token-vault",
  "version": "1.0.0",
  "description": "Secure credential management MCP server with encryption, access control, and audit logging",
  "tools": [
    {
      "name": "store_secret",
      "description": "Store a secret securely in the vault",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Secret name" },
          "value": { "type": "string", "description": "Secret value" },
          "type": { "type": "string", "enum": ["api_key", "oauth_token", "certificate", "password", "other"] },
          "environment": { "type": "string", "enum": ["development", "staging", "production"] },
          "metadata": { "type": "object" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "rotationDays": { "type": "integer" }
        },
        "required": ["name", "value", "type"]
      }
    },
    {
      "name": "get_secret",
      "description": "Retrieve a secret from the vault",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "environment": { "type": "string" },
          "reason": { "type": "string", "description": "Reason for access (audit)" }
        },
        "required": ["name"]
      }
    },
    {
      "name": "delete_secret",
      "description": "Securely delete a secret",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "environment": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    {
      "name": "rotate_secret",
      "description": "Rotate a secret (generate new value)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "newValue": { "type": "string" },
          "keepHistory": { "type": "boolean", "default": true }
        },
        "required": ["name"]
      }
    },
    {
      "name": "list_secrets",
      "description": "List all secrets (without values)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "environment": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    },
    {
      "name": "grant_access",
      "description": "Grant temporary access to a secret",
      "inputSchema": {
        "type": "object",
        "properties": {
          "secretName": { "type": "string" },
          "grantee": { "type": "string", "description": "Who to grant access to" },
          "duration": { "type": "integer", "description": "Duration in minutes" },
          "permissions": { "type": "array", "items": { "type": "string", "enum": ["read", "write"] } }
        },
        "required": ["secretName", "grantee", "duration"]
      }
    },
    {
      "name": "get_audit_log",
      "description": "Get audit log for secret access",
      "inputSchema": {
        "type": "object",
        "properties": {
          "secretName": { "type": "string" },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" }
        }
      }
    },
    {
      "name": "generate_token",
      "description": "Generate a new random token/key",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["api_key", "jwt_secret", "password", "random"] },
          "length": { "type": "integer", "default": 32 }
        },
        "required": ["type"]
      }
    }
  ],
  "resources": [
    {
      "uri": "token-vault://secrets",
      "name": "Secrets List",
      "mimeType": "application/json"
    },
    {
      "uri": "token-vault://audit/recent",
      "name": "Recent Audit Log",
      "mimeType": "application/json"
    }
  ],
  "config": {
    "encryption": {
      "algorithm": "AES-256-GCM",
      "keyDerivation": "PBKDF2"
    },
    "audit": {
      "retentionDays": 365,
      "alertOnSuspicious": true
    },
    "rotation": {
      "defaultDays": 90,
      "reminderDays": 7
    }
  }
}
