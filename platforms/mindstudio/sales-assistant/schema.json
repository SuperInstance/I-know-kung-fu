{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sales Assistant Agent Workflow Schema",
  "description": "Defines the workflow structure for the Sales Assistant Agent",
  "type": "object",
  "properties": {
    "workflow_id": {
      "type": "string",
      "description": "Unique identifier for the workflow instance"
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "input": {
      "type": "object",
      "properties": {
        "lead_data": {
          "type": "object",
          "properties": {
            "lead_id": { "type": "string" },
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "company": { "type": "string" },
            "title": { "type": "string" },
            "source": { "type": "string" },
            "original_inquiry": { "type": "string" }
          },
          "required": ["email"]
        },
        "interaction_type": {
          "type": "string",
          "enum": ["inbound", "outbound", "follow_up", "nurture", "meeting_prep"],
          "description": "Type of sales interaction"
        },
        "context": {
          "type": "object",
          "properties": {
            "campaign_id": { "type": "string" },
            "previous_interactions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "date": { "type": "string", "format": "date-time" },
                  "channel": { "type": "string" },
                  "summary": { "type": "string" },
                  "outcome": { "type": "string" }
                }
              }
            },
            "engagement_score": { "type": "number" },
            "website_activity": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "page": { "type": "string" },
                  "timestamp": { "type": "string", "format": "date-time" },
                  "duration_seconds": { "type": "integer" }
                }
              }
            }
          }
        }
      },
      "required": ["lead_data", "interaction_type"]
    },
    "processing_stages": {
      "type": "object",
      "properties": {
        "lead_enrichment": {
          "type": "object",
          "properties": {
            "company_info": {
              "type": "object",
              "properties": {
                "industry": { "type": "string" },
                "company_size": { "type": "string" },
                "revenue_range": { "type": "string" },
                "technologies": { "type": "array", "items": { "type": "string" } },
                "location": { "type": "string" }
              }
            },
            "contact_info": {
              "type": "object",
              "properties": {
                "linkedin_url": { "type": "string" },
                "seniority_level": { "type": "string" },
                "department": { "type": "string" },
                "decision_maker_score": { "type": "number" }
              }
            },
            "intent_signals": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "signal_type": { "type": "string" },
                  "signal_strength": { "type": "number" },
                  "source": { "type": "string" }
                }
              }
            }
          }
        },
        "lead_scoring": {
          "type": "object",
          "properties": {
            "total_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Overall lead score (0-100)"
            },
            "score_breakdown": {
              "type": "object",
              "properties": {
                "demographic_score": { "type": "number" },
                "firmographic_score": { "type": "number" },
                "behavioral_score": { "type": "number" },
                "engagement_score": { "type": "number" },
                "intent_score": { "type": "number" }
              }
            },
            "score_tier": {
              "type": "string",
              "enum": ["cold", "warm", "hot", "qualified"]
            },
            "score_factors": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "factor": { "type": "string" },
                  "impact": { "type": "number" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "qualification_assessment": {
          "type": "object",
          "properties": {
            "budget": {
              "type": "object",
              "properties": {
                "status": { "type": "string", "enum": ["confirmed", "likely", "unknown", "no_budget"] },
                "range": { "type": "string" },
                "confidence": { "type": "number" }
              }
            },
            "authority": {
              "type": "object",
              "properties": {
                "status": { "type": "string", "enum": ["decision_maker", "influencer", "evaluator", "unknown"] },
                "confidence": { "type": "number" }
              }
            },
            "need": {
              "type": "object",
              "properties": {
                "status": { "type": "string", "enum": ["urgent", "defined", "exploring", "none"] },
                "pain_points": { "type": "array", "items": { "type": "string" } },
                "use_case": { "type": "string" }
              }
            },
            "timeline": {
              "type": "object",
              "properties": {
                "status": { "type": "string", "enum": ["immediate", "this_quarter", "future", "unknown"] },
                "specific_date": { "type": "string" },
                "confidence": { "type": "number" }
              }
            },
            "overall_qualification": {
              "type": "string",
              "enum": ["qualified", "partially_qualified", "not_qualified", "needs_nurturing"]
            }
          }
        },
        "recommendation": {
          "type": "object",
          "properties": {
            "recommended_action": {
              "type": "string",
              "enum": ["schedule_meeting", "send_proposal", "nurture_sequence", "handoff_to_sales", "disqualify", "further_qualification"]
            },
            "priority": {
              "type": "string",
              "enum": ["immediate", "high", "medium", "low"]
            },
            "suggested_approach": { "type": "string" },
            "talking_points": {
              "type": "array",
              "items": { "type": "string" }
            },
            "objection_responses": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "objection": { "type": "string" },
                  "response": { "type": "string" }
                }
              }
            },
            "products_recommended": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "product": { "type": "string" },
                  "relevance_score": { "type": "number" },
                  "estimated_value": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "response_message": {
          "type": "string",
          "description": "The agent's response to the prospect"
        },
        "response_type": {
          "type": "string",
          "enum": ["qualification_question", "information", "meeting_request", "proposal_preview", "handoff_notice", "nurture_content"]
        },
        "crm_updates": {
          "type": "object",
          "properties": {
            "lead_score": { "type": "number" },
            "lead_status": { "type": "string" },
            "notes": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        },
        "next_steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "due_date": { "type": "string" },
              "assigned_to": { "type": "string" }
            }
          }
        },
        "meeting_scheduled": {
          "type": "object",
          "properties": {
            "scheduled": { "type": "boolean" },
            "date": { "type": "string", "format": "date-time" },
            "attendees": { "type": "array", "items": { "type": "string" } },
            "meeting_link": { "type": "string" }
          }
        },
        "handoff_required": { "type": "boolean" },
        "handoff_details": {
          "type": "object",
          "properties": {
            "reason": { "type": "string" },
            "assigned_rep": { "type": "string" },
            "context_summary": { "type": "string" }
          }
        }
      },
      "required": ["response_message", "response_type"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "processing_time_ms": { "type": "integer" },
        "model_version": { "type": "string" }
      }
    }
  },
  "required": ["workflow_id", "input", "output"]
}
